# Bot Configuration
BOT_TOKEN=your_bot_token_here

# Admin IDs (comma-separated Telegram user IDs)
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# Database path (SQLite)
DATABASE_PATH=bottega_hub/data/bottega.db

# Minimum check amount for visit (rubles)
MIN_CHECK_AMOUNT=3000

# Loyalty program settings
VISITS_REQUIRED=9
CYCLE_DAYS=60
MAX_REWARD_AMOUNT=3000

# Notification settings (days of inactivity)
INACTIVE_DAYS_NOTIFY=7
